{
  "name": "@esbla/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node ../../scripts/build/clean-typescript-output.mjs && tsc -p tsconfig.build.json",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "test": "vitest run src/server.test.ts src/workforce-detail-routes.test.ts src/workforce-list-routes.test.ts src/workforce-reporting-routes.test.ts && pnpm run test:integration",
    "test:integration": "pnpm run test:integration:employment && pnpm run test:integration:hr && pnpm run test:integration:shift && pnpm run test:integration:workforce-settings && pnpm run test:integration:workspace",
    "test:integration:employment": "node ../../scripts/test/with-postgres.mjs vitest run --maxWorkers=1 src/employment-routes.integration.test.ts",
    "test:integration:hr": "node ../../scripts/test/with-postgres.mjs vitest run --maxWorkers=1 src/hr-routes.integration.test.ts",
    "test:integration:shift": "node ../../scripts/test/with-postgres.mjs vitest run --maxWorkers=1 src/hr-shift-assignment-routes.integration.test.ts",
    "test:integration:workforce-settings": "node ../../scripts/test/with-postgres.mjs vitest run --maxWorkers=1 src/workforce-service-settings.integration.test.ts",
    "test:integration:workspace": "node ../../scripts/test/with-postgres.mjs vitest run --maxWorkers=1 src/workspace-routes.integration.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@esbla/contracts": "workspace:^",
    "@esbla/db": "workspace:^",
    "@esbla/hr": "workspace:^",
    "@esbla/observability": "workspace:^",
    "@esbla/platform-core": "workspace:^",
    "@esbla/workspace": "workspace:^",
    "fastify": "5.10.0",
    "pg": "8.22.0"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "@types/pg": "8.20.0",
    "tsx": "4.23.0",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
