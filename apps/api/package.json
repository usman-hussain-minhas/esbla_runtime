  "dependencies": {
    "@esbla/observability": "workspace:^",
    "fastify": "5.10.0"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "tsx": "4.23.0",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
