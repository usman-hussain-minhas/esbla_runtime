{
  "name": "esbla-runtime",
  "version": "0.0.0",
  "private": true,
  "description": "Public runtime implementation for Esbla",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "pnpm -r --sort --if-present build",
    "ci": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "dev": "pnpm --parallel --filter @esbla/api --filter @esbla/web dev",
    "format": "biome format --write .",
    "lint": "biome check .",
    "test": "pnpm -r --sort --if-present test",
    "typecheck": "pnpm -r --sort --if-present typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
