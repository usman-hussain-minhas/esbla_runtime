{
  "name": "@esbla/contracts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./development-principal": {
      "types": "./src/development-principal.ts",
      "development": "./src/development-principal.ts",
      "import": "./dist/development-principal.js"
    },
    "./hr-leave-api": {
      "types": "./src/hr-leave-api.ts",
      "development": "./src/hr-leave-api.ts",
      "import": "./dist/hr-leave-api.js"
    }
  },
  "scripts": {
    "build": "node ../../scripts/build/clean-typescript-output.mjs && tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
